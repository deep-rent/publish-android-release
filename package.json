{
  "name": "publish-android-release",
  "version": "2.1.2",
  "description": "GitHub Action for building, signing, and uploading Android App Bundle (AAB) artifacts to the Google Play Console.",
  "license": "MIT",
  "author": "deep.rent GmbH",
  "private": true,
  "keywords": [
    "actions"
  ],
  "homepage": "https://github.com/deep-rent/publish-android-release#readme",
  "bugs": {
    "email": "support@deep.rent",
    "url": "https://github.com/deep-rent/publish-android-release/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deep-rent/publish-android-release.git"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "all": "npm run format:write && npm run lint && npm run test && npm run build",
    "build:watch": "npm run build -- --watch",
    "build": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "coverage": "npx make-coverage-badge --output-path .github/assets/coverage.svg",
    "format:check": "npx prettier --check .",
    "format:write": "npx prettier --write .",
    "lint:fix": "npx eslint . --fix",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/exec": "3.0.0",
    "googleapis": "171.4.0"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@github/local-action": "7.0.1",
    "@jest/globals": "30.3.0",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.1",
    "eslint-plugin-license-header": "0.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.4.0",
    "jest": "30.3.0",
    "make-coverage-badge": "1.2.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "rollup": "4.60.0",
    "ts-jest": "29.4.9",
    "ts-jest-resolver": "2.0.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
